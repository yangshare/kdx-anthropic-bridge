# 代理自身鉴权 key —— Claude Code 用它当 ANTHROPIC_AUTH_TOKEN
# 自己设一个随机字符串
KDX_PROXY_KEY=change-me-to-a-random-string

# 科大上游 key(appid:secret 格式)
UPSTREAM_API_KEY=your-keding-key-here

# 科大上游 Anthropic 端点
UPSTREAM_BASE_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/anthropic

# 上游重试:上游返回 502/503/429 时,按固定间隔重试,直到成功或达上限
# 重试次数(不含首次),默认 20。0 = 不重试
UPSTREAM_MAX_RETRIES=20
# 重试间隔(秒),默认 5
UPSTREAM_RETRY_INTERVAL_SEC=5

# 代理监听
PROXY_HOST=0.0.0.0
PROXY_PORT=8080

# 谷歌搜索代理(http://host:port)—— WebSearch 功能必填,谷歌直连会超时
GOOGLE_SEARCH_PROXY=http://127.0.0.1:7890
# 谷歌搜索超时(秒)
GOOGLE_SEARCH_TIMEOUT=15
# 每次搜索返回结果数
GOOGLE_SEARCH_LIMIT=5
